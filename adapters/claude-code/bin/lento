#!/usr/bin/env bash
# Lento toggle helper. Reads/writes a state file the PostToolUse hook checks.
# State is per-directory: the file lives in the current working directory
# (or LENTO_STATE_FILE if explicitly set).
set -euo pipefail

STATE_FILE="${LENTO_STATE_FILE:-$PWD/.lento-mode}"

cmd="${1:-status}"

case "$cmd" in
  on)
    touch "$STATE_FILE"
    echo "Lento: on  ($STATE_FILE)"
    ;;
  off)
    rm -f "$STATE_FILE"
    echo "Lento: off"
    ;;
  status)
    if [ -f "$STATE_FILE" ]; then
      echo "Lento: on  ($STATE_FILE)"
    else
      echo "Lento: off"
    fi
    ;;
  *)
    echo "Usage: lento [on|off|status]" >&2
    echo "       (state file: $STATE_FILE)" >&2
    exit 2
    ;;
esac
