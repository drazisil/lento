#!/usr/bin/env bash
# Lento toggle helper. Reads/writes a state file the PostToolUse hook checks.
set -euo pipefail

STATE_DIR="${LENTO_STATE_DIR:-$HOME/.claude/lento}"
STATE_FILE="$STATE_DIR/active"

cmd="${1:-status}"

mkdir -p "$STATE_DIR"

case "$cmd" in
  on)
    touch "$STATE_FILE"
    echo "Lento: on"
    ;;
  off)
    rm -f "$STATE_FILE"
    echo "Lento: off"
    ;;
  status)
    if [ -f "$STATE_FILE" ]; then
      echo "Lento: on"
    else
      echo "Lento: off"
    fi
    ;;
  *)
    echo "Usage: lento [on|off|status]" >&2
    exit 2
    ;;
esac
